# 1. Inicializa git (si no lo has hecho en esta carpeta nueva)
git init

# 2. Agrega todos los archivos a git
git add .

# 3. Guarda los cambios
git commit -m "Organización completa del proyecto: backend y frontend"

# 4. Conecta con tu repositorio de GitHub (reemplaza con tu URL real)
git remote add origin https://github.com/TU_USUARIO/TU_REPOSITORIO.git

# 5. Sube todo a GitHub (forzando la rama main)
git branch -M main
git push -u origin main --force
