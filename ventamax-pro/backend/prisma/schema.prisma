// ─────────────────────────────────────────────────────────────
// VentaMax Pro — Esquema de base de datos (PostgreSQL)
//
// Diseñado para: 50 vendedores × ~9.000 facturas/mes = ~450k/mes.
// Reemplaza el modelo clave-valor anterior (un JSON gigante por
// entidad) por tablas normalizadas con índices.
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Usuarios y roles ─────────────────────────────────────────
enum Rol {
  ADMIN
  COADMIN
  VENDEDOR
  ENTREGADOR
}

model Usuario {
  id           String    @id @default(uuid())
  nombre       String
  usuario      String    @unique // login
  pinHash      String // PIN hasheado con bcrypt — nunca en texto plano
  rol          Rol       @default(VENDEDOR)
  activo       Boolean   @default(true)
  zona         String? // zona/ruta asignada al vendedor TAT
  creadoEn     DateTime  @default(now())
  actualizadoEn DateTime @updatedAt

  facturas  Factura[]  @relation("vendedor")
  entregas  Factura[]  @relation("entregador")
  gastos    Gasto[]

  @@index([rol, activo])
  @@map("usuarios")
}

// ── Clientes (tiendas de la ruta TAT) ────────────────────────
model Cliente {
  id            String    @id @default(uuid())
  nombre        String // nombre del negocio
  contacto      String? // nombre del tendero
  telefono      String?
  direccion     String?
  barrio        String?
  lat           Float? // para el mapa de rutas
  lng           Float?
  diaVisita     Int? // 1=lunes … 7=domingo
  cupoCredito   Decimal   @default(0) @db.Decimal(14, 2)
  saldoPendiente Decimal  @default(0) @db.Decimal(14, 2)
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  facturas Factura[]

  @@index([nombre])
  @@index([diaVisita, activo])
  @@index([barrio])
  @@map("clientes")
}

// ── Productos e inventario ───────────────────────────────────
model Producto {
  id            String   @id @default(uuid())
  codigo        String?  @unique // código de barras / SKU
  nombre        String
  categoria     String?
  precioCompra  Decimal  @default(0) @db.Decimal(14, 2)
  precioVenta   Decimal  @default(0) @db.Decimal(14, 2)
  stock         Int      @default(0)
  stockMinimo   Int      @default(0)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  items          FacturaItem[]
  movimientos    MovimientoStock[]

  @@index([nombre])
  @@index([categoria, activo])
  @@map("productos")
}

model MovimientoStock {
  id         String   @id @default(uuid())
  productoId String
  tipo       String // ENTRADA | SALIDA | AJUSTE | DEVOLUCION
  cantidad   Int
  motivo     String?
  facturaId  String?
  creadoEn   DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])

  @@index([productoId, creadoEn])
  @@map("movimientos_stock")
}

// ── Facturas (la tabla de mayor volumen: ~450k/mes) ──────────
enum EstadoFactura {
  PENDIENTE   // creada por vendedor, falta entrega
  ENTREGADA
  PAGADA
  CREDITO     // entregada, pago a crédito
  ANULADA
}

model Factura {
  id           String        @id @default(uuid())
  consecutivo  Int           @default(autoincrement()) // número visible de factura
  clienteId    String
  vendedorId   String
  entregadorId String?
  estado       EstadoFactura @default(PENDIENTE)
  subtotal     Decimal       @db.Decimal(14, 2)
  descuento    Decimal       @default(0) @db.Decimal(14, 2)
  total        Decimal       @db.Decimal(14, 2)
  pagado       Decimal       @default(0) @db.Decimal(14, 2)
  metodoPago   String? // EFECTIVO | TRANSFERENCIA | CREDITO
  notas        String?
  // Soporte offline: el cliente genera un UUID local; si reintenta
  // el envío, este campo evita duplicar la venta.
  idLocal      String?       @unique
  creadoEn     DateTime      @default(now())
  entregadoEn  DateTime?
  actualizadoEn DateTime     @updatedAt

  cliente    Cliente      @relation(fields: [clienteId], references: [id])
  vendedor   Usuario      @relation("vendedor", fields: [vendedorId], references: [id])
  entregador Usuario?     @relation("entregador", fields: [entregadorId], references: [id])
  items      FacturaItem[]

  // Índices pensados para las consultas reales de la app:
  @@index([vendedorId, creadoEn(sort: Desc)]) // "mis ventas de hoy/semana"
  @@index([clienteId, creadoEn(sort: Desc)])  // historial del cliente
  @@index([estado, creadoEn])                 // cola del entregador
  @@index([creadoEn])                         // reportes por rango de fechas
  @@map("facturas")
}

model FacturaItem {
  id         String  @id @default(uuid())
  facturaId  String
  productoId String
  cantidad   Int
  precioUnit Decimal @db.Decimal(14, 2) // precio congelado al momento de la venta
  total      Decimal @db.Decimal(14, 2)

  factura  Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@index([facturaId])
  @@index([productoId]) // "qué tanto rota este producto"
  @@map("factura_items")
}

// ── Gastos ───────────────────────────────────────────────────
model Gasto {
  id        String   @id @default(uuid())
  usuarioId String
  concepto  String
  categoria String?
  monto     Decimal  @db.Decimal(14, 2)
  fecha     DateTime @default(now())
  notas     String?

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, fecha])
  @@index([fecha])
  @@map("gastos")
}

// ── Proveedores ──────────────────────────────────────────────
model Proveedor {
  id        String   @id @default(uuid())
  nombre    String
  nit       String?
  telefono  String?
  contacto  String?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  @@index([nombre])
  @@map("proveedores")
}
