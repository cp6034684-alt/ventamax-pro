// ─────────────────────────────────────────────────────────────
// VentaMax Pro — Esquema de base de datos (PostgreSQL)
//
// Diseñado para: 50 vendedores × ~9.000 facturas/mes = ~450k/mes.
// Reemplaza el modelo clave-valor anterior (un JSON gigante por
// entidad) por tablas normalizadas con índices.
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Usuarios y roles ─────────────────────────────────────────
enum Rol {
  ADMIN
  COADMIN
  SUPERVISOR
  VENDEDOR
  ENTREGADOR
}

model Usuario {
  id           String    @id @default(uuid())
  nombre       String
  usuario      String    @unique // login
  pinHash      String // PIN hasheado con bcrypt — nunca en texto plano
  rol          Rol       @default(VENDEDOR)
  activo       Boolean   @default(true)
  zona         String? // zona/ruta asignada al vendedor TAT
  documento    String? // cédula / documento del vendedor (sale en el reporte)
  ciudad       String? // ciudad base del usuario
  telefono     String? // teléfono del vendedor (sale en el recordatorio)
  meta         Int       @default(10000000) // meta de venta mensual (para el % de meta del dashboard)
  listasPrecios String[] @default([]) // listas de precio que puede usar
  regionId     String? // región asignada (define su bodega para las ventas)
  supervisorId String? // vendedor: supervisor a cargo
  creadoEn     DateTime  @default(now())
  actualizadoEn DateTime @updatedAt

  facturas  Factura[]  @relation("vendedor")
  entregas  Factura[]  @relation("entregador")
  gastos    Gasto[]
  tareas    Tarea[]    @relation("tareasEntregador")
  region    Region?    @relation(fields: [regionId], references: [id])
  supervisor Usuario?  @relation("equipo", fields: [supervisorId], references: [id])
  acargo    Usuario[] @relation("equipo")
  actividades Actividad[]

  @@index([rol, activo])
  @@map("usuarios")
}

// ── Tarea de entrega (programación): agrupa pedidos asignados a un entregador ──
model Tarea {
  id           String   @id @default(uuid())
  nombre       String
  entregadorId String
  fecha        DateTime @default(now())
  estado       String   @default("activa") // activa | completada
  creadoEn     DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  entregador Usuario   @relation("tareasEntregador", fields: [entregadorId], references: [id])
  facturas   Factura[]

  @@index([entregadorId, estado])
  @@map("tareas_entrega")
}

// ── Clientes (tiendas de la ruta TAT) ────────────────────────
model Cliente {
  id            String    @id @default(uuid())
  codigo        Int?      @unique // código del sistema (VMX-####); puede quedar vacío y asignarse luego
  nombre        String // nombre del negocio
  razonSocial   String? // nombre legal del cliente (puede diferir del negocio)
  contacto      String? // nombre del tendero
  telefono      String?
  direccion     String?
  barrio        String?
  ciudad        String?
  correo        String? // email para facturación electrónica (DIAN)
  nit           String? // NIT/CC del cliente
  zona          String? // zona/ruta del export
  segmento      String? // segmento comercial (TIENDA, etc.)
  tipologia     String? // tipología del cliente (define la lista de precio)
  listaPrecio   String? // lista de precio asignada al cliente (según tipología)
  lat           Float? // para el mapa de rutas
  lng           Float?
  diaVisita     Int? // 1=lunes … 7=domingo
  cupoCredito   Decimal   @default(0) @db.Decimal(14, 2)
  saldoPendiente Decimal  @default(0) @db.Decimal(14, 2)
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  facturas Factura[]

  @@index([nombre])
  @@index([diaVisita, activo])
  @@index([barrio])
  @@index([ciudad])
  @@map("clientes")
}

// ── Visitas sin compra (causal de no compra) ─────────────────
// Registra cuando un vendedor visitó un cliente pero NO compró.
// Sirve para sacarlo de "pendientes por visitar" del día en el mapa.
model Visita {
  id         String   @id @default(uuid())
  clienteId  String
  vendedorId String
  causal     String // motivo de no compra
  notas      String?
  creadoEn   DateTime @default(now())

  @@index([clienteId, creadoEn])
  @@index([vendedorId, creadoEn])
  @@map("visitas")
}

// ── Regiones y bodegas (la empresa opera en varias regiones) ──
model Region {
  id                String   @id @default(uuid())
  nombre            String   @unique
  activo            Boolean  @default(true)
  bodegaPrincipalId String? // bodega de la que despachan/descuentan los vendedores de esta región
  creadoEn          DateTime @default(now())

  bodegas   Bodega[]
  usuarios  Usuario[]

  @@map("regiones")
}

model Bodega {
  id        String   @id @default(uuid())
  nombre    String
  codigo    String?
  ciudad    String?
  direccion String?
  regionId  String?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  region    Region?  @relation(fields: [regionId], references: [id])
  stock     StockBodega[]
  cargas    CargaInventario[]

  @@index([regionId])
  @@map("bodegas")
}

// ── Rastreo: migas de pan del recorrido del vendedor en campo ──
// Se guarda un punto solo cuando el vendedor se desplaza (≥30m), para
// reconstruir su trayecto del día. La ubicación en vivo va por presencia.
model Ubicacion {
  id         String   @id @default(uuid())
  vendedorId String
  lat        Float
  lng        Float
  creadoEn   DateTime @default(now())

  @@index([vendedorId, creadoEn])
  @@map("ubicaciones")
}

// ── Productos e inventario ───────────────────────────────────
model Producto {
  id            String   @id @default(uuid())
  codigo        String?  @unique // código de barras / SKU
  nombre        String
  categoria     String? // categoría
  marca         String? // marca del producto
  linea         String? // línea
  segmento      String? // segmento
  subsegmento   String? // subsegmento
  unidad        String? // unidad o embalaje
  iva           Decimal  @default(0) @db.Decimal(5, 2) // % de IVA del producto (0 = exento)
  precioCompra  Decimal  @default(0) @db.Decimal(14, 2) // costo
  precioVenta   Decimal  @default(0) @db.Decimal(14, 2) // precio por defecto (= lista TAT)
  // Listas de precio: el vendedor cobra con una de estas según su asignación.
  precioGeneral     Decimal @default(0) @db.Decimal(14, 2)
  precioMayorista   Decimal @default(0) @db.Decimal(14, 2)
  precioTat         Decimal @default(0) @db.Decimal(14, 2)
  precioDroguerias  Decimal @default(0) @db.Decimal(14, 2)
  precioTatViajeros Decimal @default(0) @db.Decimal(14, 2)
  precioEntreSede   Decimal @default(0) @db.Decimal(14, 2)
  stock         Int      @default(0)
  stockMinimo   Int      @default(0)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  items          FacturaItem[]
  movimientos    MovimientoStock[]
  stockBodega    StockBodega[]

  @@index([nombre])
  @@index([categoria, activo])
  @@map("productos")
}

model MovimientoStock {
  id         String   @id @default(uuid())
  productoId String
  tipo       String // ENTRADA | SALIDA | AJUSTE | DEVOLUCION
  cantidad   Int
  motivo     String?
  facturaId  String?
  creadoEn   DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])

  @@index([productoId, creadoEn])
  @@map("movimientos_stock")
}

// ── Facturas (la tabla de mayor volumen: ~450k/mes) ──────────
enum EstadoFactura {
  PENDIENTE   // creada por vendedor, falta entrega
  ENTREGADA
  PAGADA
  CREDITO     // entregada, pago a crédito
  DEVUELTA    // no entregada / devuelta totalmente (fuera de la cola)
  ANULADA
}

model Factura {
  id           String        @id @default(uuid())
  consecutivo  Int           @default(autoincrement()) // número visible de factura
  tipoDoc      String        @default("VENTA") // VENTA | DEVOLUCION (las devoluciones llevan cantidades negativas)
  clienteId    String
  vendedorId   String
  entregadorId String?
  estado       EstadoFactura @default(PENDIENTE)
  subtotal     Decimal       @db.Decimal(14, 2)
  descuento    Decimal       @default(0) @db.Decimal(14, 2)
  total        Decimal       @db.Decimal(14, 2)
  pagado       Decimal       @default(0) @db.Decimal(14, 2)
  metodoPago   String? // EFECTIVO | TRANSFERENCIA | CREDITO
  listaPrecio  String? // lista de precio usada (GENERAL/MAYORISTA/TAT/DROGUERIAS)
  notas        String?
  // Devolución: la venta origen guarda el resumen; las devoluciones físicas
  // se registran como documentos DEVOLUCION (negativos) enlazados por facturaOrigenId.
  devuelta          String   @default("NO") // NO | PARCIAL | TOTAL
  causal            String? // motivo de la devolución
  obsDevolucion     String? // observación de la devolución
  montoDevuelto     Decimal  @default(0) @db.Decimal(14, 2)
  revivirSolicitado Boolean  @default(false) // el vendedor pidió revivir un pedido devuelto
  facturaOrigenId   String? // si es DEVOLUCION, apunta a la venta original
  tareaId           String? // tarea de entrega (programación) a la que pertenece el pedido
  // Soporte offline: el cliente genera un UUID local; si reintenta
  // el envío, este campo evita duplicar la venta.
  idLocal      String?       @unique
  creadoEn     DateTime      @default(now())
  entregadoEn  DateTime?
  actualizadoEn DateTime     @updatedAt

  cliente    Cliente      @relation(fields: [clienteId], references: [id])
  vendedor   Usuario      @relation("vendedor", fields: [vendedorId], references: [id])
  entregador Usuario?     @relation("entregador", fields: [entregadorId], references: [id])
  items      FacturaItem[]
  facturaOrigen Factura?  @relation("origenDevol", fields: [facturaOrigenId], references: [id])
  devoluciones  Factura[] @relation("origenDevol")
  tarea      Tarea?       @relation(fields: [tareaId], references: [id])

  // Índices pensados para las consultas reales de la app:
  @@index([vendedorId, creadoEn(sort: Desc)]) // "mis ventas de hoy/semana"
  @@index([clienteId, creadoEn(sort: Desc)])  // historial del cliente
  @@index([estado, creadoEn])                 // cola del entregador
  @@index([creadoEn])                         // reportes por rango de fechas
  @@index([facturaOrigenId])
  @@index([tareaId])
  @@map("facturas")
}

model FacturaItem {
  id         String  @id @default(uuid())
  facturaId  String
  productoId String
  cantidad   Int
  precioUnit Decimal @db.Decimal(14, 2) // precio congelado al momento de la venta
  total      Decimal @db.Decimal(14, 2)

  factura  Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@index([facturaId])
  @@index([productoId]) // "qué tanto rota este producto"
  @@map("factura_items")
}

// ── Gastos ───────────────────────────────────────────────────
model Gasto {
  id        String   @id @default(uuid())
  usuarioId String
  concepto  String
  categoria String?
  monto     Decimal  @db.Decimal(14, 2)
  fecha     DateTime @default(now())
  notas     String?

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, fecha])
  @@index([fecha])
  @@map("gastos")
}

// ── Proveedores ──────────────────────────────────────────────
model Proveedor {
  id        String   @id @default(uuid())
  nombre    String
  nit       String?
  telefono  String?
  contacto  String?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  @@index([nombre])
  @@map("proveedores")
}

// ── Inventario por bodega ─────────────────────────────────────
model StockBodega {
  id         String   @id @default(uuid())
  productoId String
  bodegaId   String
  cantidad   Int      @default(0)

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  bodega   Bodega   @relation(fields: [bodegaId], references: [id], onDelete: Cascade)

  @@unique([productoId, bodegaId])
  @@index([bodegaId])
  @@map("stock_bodega")
}

model CargaInventario {
  id         String   @id @default(uuid())
  bodegaId   String
  usuarioId  String?
  archivo    String?
  totalItems Int      @default(0)
  revertida  Boolean  @default(false)
  creadoEn   DateTime @default(now())

  bodega Bodega @relation(fields: [bodegaId], references: [id], onDelete: Cascade)
  items  CargaInventarioItem[]

  @@index([bodegaId, creadoEn])
  @@map("cargas_inventario")
}

model CargaInventarioItem {
  id               String @id @default(uuid())
  cargaId          String
  productoId       String
  cantidadAnterior Int
  cantidadNueva    Int

  carga CargaInventario @relation(fields: [cargaId], references: [id], onDelete: Cascade)

  @@index([cargaId])
  @@map("cargas_inventario_items")
}

model Actividad {
  id        String   @id @default(uuid())
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
  tipo      String   // LOGIN | LOGOUT | VENTA | IMPORTACION
  detalle   String?
  creadoEn  DateTime @default(now())

  @@index([creadoEn])
  @@index([usuarioId])
  @@map("actividades")
}
